---
import Navbar from '../components/Navbar.astro';
import { getCollection } from 'astro:content';
import CaseStudyCard from '../components/CaseStudyCard.jsx';
const caseStudies = await getCollection('caseStudies');
---
<Navbar />
<section class="container mx-auto py-16 text-center">
  <h1 class="text-4xl font-extrabold text-brandGreen mb-4">Trailblazer Analytics</h1>
  <p class="max-w-xl mx-auto">Transforming data into actionable insight with BI expertise, AI innovation, and clear storytelling.</p>
  <a href="/contact" class="mt-6 inline-block bg-brandGold text-white py-3 px-6 rounded-lg">Start a conversation</a>
</section>

<section class="container mx-auto py-16">
  <h2 class="text-2xl font-bold mb-6">Case Studies</h2>
  <div class="grid gap-6 md:grid-cols-2">
    {caseStudies.map(cs => (
      <CaseStudyCard {...cs.data} />
    ))}
  </div>
</section>
