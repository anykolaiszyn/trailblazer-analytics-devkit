---
import Navbar from '../components/Navbar.astro';
---
<Navbar />
<section class="container mx-auto py-12">
  <h2 class="text-3xl font-bold mb-4">Contact</h2>
  <form action="https://formspree.io/f/yourID" method="POST" class="max-w-lg mx-auto space-y-4">
    <input type="text" name="name" required placeholder="Name" class="w-full border p-2 rounded"/>
    <input type="email" name="_replyto" required placeholder="Email" class="w-full border p-2 rounded"/>
    <!-- Honeypot field for spam protection -->
    <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
    <textarea name="message" required placeholder="Message" class="w-full border p-2 rounded h-32"></textarea>
    <button type="submit" class="bg-brandGreen text-white py-2 px-4 rounded">Send</button>
  </form>
</section>
