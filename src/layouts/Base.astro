---
import '../styles/global.css';
import siteConfig from '../site.config.js';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>Trailblazer Analytics</title>
    <meta name="description" content="Transforming data into actionable insight with BI expertise, AI innovation, and clear storytelling." />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:title" content="Trailblazer Analytics" />
    <meta property="og:description" content="Transforming data into actionable insight with BI expertise, AI innovation, and clear storytelling." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://trailblazer-analytics.com" />
    <meta property="og:image" content="/og-image.png" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What does Trailblazer Analytics do?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "We transform data into actionable insight with BI expertise, AI innovation, and clear storytelling."
            }
          }
        ]
      }
    </script>
    <script defer data-domain={siteConfig.plausibleDomain} src="https://plausible.io/js/plausible.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <style>
      html { font-family: 'Inter', 'Outfit', sans-serif; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
