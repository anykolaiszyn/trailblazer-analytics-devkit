---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.jsx';

// SEO meta data
const seoData = {
  title: "Free Downloads - Data Strategy Templates & Analytics Tools",
  description: "Get free data strategy templates, analytics checklists, and BI tools. Instantly download frameworks, canvases, and guides to accelerate your data transformation journey.",
  image: "/og-image-downloads.png"
};

// Free download categories
const downloadCategories = [
  {
    id: 'starter-kits',
    title: 'Starter Kits',
    description: 'Complete packages to jumpstart your data initiatives',
    downloads: [
      {
        name: 'Data Strategy Starter Kit',
        description: 'Everything you need to develop your first data strategy including canvas, templates, and examples.',
        fileSize: '15 MB',
        fileType: 'ZIP',
        downloads: 8500,
        rating: 4.9,
        includes: ['Strategy Canvas', 'Roadmap Template', 'Stakeholder Map', 'ROI Calculator', '50+ Examples'],
        preview: '/previews/data-strategy-kit.png'
      },
      {
        name: 'Dashboard Design Kit',
        description: 'Professional dashboard templates and design guidelines for creating effective data visualizations.',
        fileSize: '22 MB',
        fileType: 'ZIP',
        downloads: 6200,
        rating: 4.8,
        includes: ['10 Dashboard Templates', 'Design Guidelines', 'Color Palettes', 'Icon Library', 'Best Practices Guide'],
        preview: '/previews/dashboard-kit.png'
      },
      {
        name: 'Data Governance Toolkit',
        description: 'Comprehensive set of templates and frameworks for establishing data governance.',
        fileSize: '18 MB',
        fileType: 'ZIP',
        downloads: 4800,
        rating: 4.7,
        includes: ['Governance Framework', 'Policy Templates', 'RACI Matrix', 'Data Dictionary Template', 'Compliance Checklist'],
        preview: '/previews/governance-kit.png'
      }
    ]
  },
  {
    id: 'templates',
    title: 'Templates & Frameworks',
    description: 'Ready-to-use templates for common data and analytics tasks',
    downloads: [
      {
        name: 'Analytics Requirements Template',
        description: 'Structured template for gathering and documenting analytics requirements from stakeholders.',
        fileSize: '2.5 MB',
        fileType: 'DOCX',
        downloads: 5600,
        rating: 4.6,
        includes: ['Requirements Template', 'Stakeholder Interview Guide', 'User Story Examples', 'Acceptance Criteria Framework'],
        preview: '/previews/requirements-template.png'
      },
      {
        name: 'Data Quality Assessment Framework',
        description: 'Systematic approach to evaluate and improve data quality across your organization.',
        fileSize: '4.2 MB',
        fileType: 'XLSX',
        downloads: 4200,
        rating: 4.8,
        includes: ['Assessment Scorecard', 'Quality Metrics', 'Issue Tracking Template', 'Improvement Plan Template'],
        preview: '/previews/quality-framework.png'
      },
      {
        name: 'Business Intelligence Roadmap Template',
        description: 'Strategic planning template for developing comprehensive BI implementation roadmaps.',
        fileSize: '3.8 MB',
        fileType: 'PPTX',
        downloads: 3900,
        rating: 4.5,
        includes: ['Roadmap Template', 'Milestone Tracker', 'Resource Planning', 'Risk Assessment Matrix'],
        preview: '/previews/bi-roadmap.png'
      }
    ]
  },
  {
    id: 'checklists',
    title: 'Checklists & Guides',
    description: 'Step-by-step guides and checklists for data best practices',
    downloads: [
      {
        name: 'Data Project Checklist',
        description: 'Comprehensive checklist to ensure your data projects stay on track and deliver value.',
        fileSize: '1.2 MB',
        fileType: 'PDF',
        downloads: 7200,
        rating: 4.9,
        includes: ['Project Planning Checklist', 'Quality Gates', 'Testing Framework', 'Go-Live Checklist'],
        preview: '/previews/project-checklist.png'
      },
      {
        name: 'Analytics Ethics Guidelines',
        description: 'Best practices and guidelines for ethical use of data and analytics in your organization.',
        fileSize: '2.1 MB',
        fileType: 'PDF',
        downloads: 2800,
        rating: 4.7,
        includes: ['Ethics Framework', 'Decision Tree', 'Policy Examples', 'Training Materials'],
        preview: '/previews/ethics-guide.png'
      },
      {
        name: 'Cloud Migration Checklist',
        description: 'Step-by-step guide for migrating your data infrastructure to the cloud.',
        fileSize: '3.5 MB',
        fileType: 'PDF',
        downloads: 3600,
        rating: 4.6,
        includes: ['Migration Planning', 'Security Checklist', 'Cost Optimization', 'Testing Framework'],
        preview: '/previews/cloud-migration.png'
      }
    ]
  },
  {
    id: 'calculators',
    title: 'Calculators & Tools',
    description: 'Interactive tools for planning and measuring success',
    downloads: [
      {
        name: 'Analytics ROI Calculator',
        description: 'Calculate the return on investment for your analytics initiatives with this comprehensive tool.',
        fileSize: '1.8 MB',
        fileType: 'XLSX',
        downloads: 9200,
        rating: 4.8,
        includes: ['ROI Calculator', 'Cost Templates', 'Benefit Tracking', 'Scenario Planning'],
        preview: '/previews/roi-calculator.png'
      },
      {
        name: 'Data Team Sizing Calculator',
        description: 'Determine the optimal size and composition of your data team based on organizational needs.',
        fileSize: '1.5 MB',
        fileType: 'XLSX',
        downloads: 2900,
        rating: 4.5,
        includes: ['Team Sizing Model', 'Role Definitions', 'Skill Matrix', 'Budget Planner'],
        preview: '/previews/team-calculator.png'
      },
      {
        name: 'Data Storage Cost Estimator',
        description: 'Estimate and optimize your data storage costs across different cloud providers.',
        fileSize: '2.2 MB',
        fileType: 'XLSX',
        downloads: 1800,
        rating: 4.4,
        includes: ['Cost Comparison', 'Growth Projections', 'Optimization Tips', 'Provider Analysis'],
        preview: '/previews/storage-estimator.png'
      }
    ]
  }
];

// Most popular downloads
const popularDownloads = [
  'Analytics ROI Calculator',
  'Data Strategy Starter Kit',
  'Data Project Checklist',
  'Dashboard Design Kit'
];

function formatNumber(num) {
  if (num >= 1000) {
    return (num / 1000).toFixed(1) + 'k';
  }
  return num.toString();
}
---

<Base {...seoData}>
  <Navbar />
  
  <!-- Header Section -->
  <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          Free <span class="text-brandGold">Downloads</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-8">
          Professional templates, frameworks, and tools to accelerate your data journey. All completely free.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <span class="bg-green-500/20 text-green-400 px-4 py-2 rounded-full">✓ No Email Required</span>
          <span class="bg-brandGold/20 text-brandGold px-4 py-2 rounded-full">✓ Instant Download</span>
          <span class="bg-blue-500/20 text-blue-400 px-4 py-2 rounded-full">✓ Commercial Use OK</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Downloads -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Most Popular Downloads</h2>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
          {popularDownloads.map((downloadName) => {
            const download = downloadCategories
              .flatMap(cat => cat.downloads)
              .find(d => d.name === downloadName);
            
            return download && (
              <div class="bg-gradient-to-br from-brandGreen to-green-600 rounded-xl p-6 text-white text-center">
                <div class="w-12 h-12 bg-white/20 rounded-lg flex items-center justify-center mx-auto mb-4">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <h3 class="font-bold mb-2">{download.name}</h3>
                <p class="text-sm opacity-90 mb-3">{formatNumber(download.downloads)} downloads</p>
                <button class="bg-white text-brandGreen px-4 py-2 rounded-lg font-semibold text-sm hover:bg-gray-100 transition-colors">
                  Download Free
                </button>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Download Categories -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Browse All Downloads</h2>
          <p class="text-lg text-gray-600">Over 50+ professional resources to help you succeed with data and analytics</p>
        </div>
        
        <div class="space-y-16">
          {downloadCategories.map((category) => (
            <div id={category.id}>
              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{category.title}</h3>
                <p class="text-lg text-gray-600">{category.description}</p>
              </div>
              
              <div class="grid lg:grid-cols-2 xl:grid-cols-3 gap-8">
                {category.downloads.map((download) => (
                  <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
                    <div class="h-48 bg-gray-100 flex items-center justify-center">
                      <div class="text-center">
                        <div class="w-16 h-16 bg-brandGreen rounded-lg flex items-center justify-center mx-auto mb-2">
                          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                          </svg>
                        </div>
                        <span class="text-sm text-gray-500">Preview Available</span>
                      </div>
                    </div>
                    
                    <div class="p-6">
                      <div class="flex justify-between items-start mb-3">
                        <h4 class="text-xl font-bold text-gray-900">{download.name}</h4>
                        <div class="flex items-center gap-1">
                          <svg class="w-4 h-4 text-brandGold" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                          <span class="text-sm font-semibold text-gray-700">{download.rating}</span>
                        </div>
                      </div>
                      
                      <p class="text-gray-600 mb-4">{download.description}</p>
                      
                      <div class="mb-4">
                        <h5 class="font-semibold text-gray-900 mb-2">Includes:</h5>
                        <div class="flex flex-wrap gap-2">
                          {download.includes.slice(0, 3).map(item => (
                            <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-sm">{item}</span>
                          ))}
                          {download.includes.length > 3 && (
                            <span class="text-brandGreen text-sm font-semibold">+{download.includes.length - 3} more</span>
                          )}
                        </div>
                      </div>
                      
                      <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center gap-4 text-sm text-gray-500">
                          <span>{download.fileSize}</span>
                          <span>•</span>
                          <span>{download.fileType}</span>
                          <span>•</span>
                          <span>{formatNumber(download.downloads)} downloads</span>
                        </div>
                      </div>
                        <div class="flex gap-3">
                        <button 
                          class="download-btn flex-1 bg-brandGreen hover:bg-green-700 text-white font-semibold py-3 px-4 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                          data-download-id={download.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}
                          data-download-title={download.name}
                        >
                          <span class="download-text">Download Free</span>
                          <span class="download-loading hidden flex items-center justify-center">
                            <svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24">
                              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Downloading...
                          </span>
                        </button>
                        <button 
                          class="preview-btn border-2 border-gray-300 hover:border-brandGreen text-gray-700 hover:text-brandGreen px-4 py-3 rounded-lg transition-colors"
                          data-preview-url={download.preview}
                        >
                          Preview
                        </button>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Resources -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">Need Something Specific?</h2>
        <div class="bg-gray-50 rounded-2xl p-8">
          <div class="w-16 h-16 bg-brandGreen rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Custom Resource Development</h3>
          <p class="text-lg text-gray-600 mb-6">
            We create custom templates, frameworks, and tools tailored to your specific industry and organizational needs.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-brandGreen text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-700 transition-colors">
              Request Custom Resource
            </a>
            <a href="/tools" class="border-2 border-brandGreen text-brandGreen px-6 py-3 rounded-lg font-semibold hover:bg-brandGreen hover:text-white transition-colors">
              View Premium Tools
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="py-16 bg-brandGreen text-white">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Get New Resources First</h2>
        <p class="text-xl mb-8 opacity-90">
          Be notified when we release new templates, frameworks, and tools.
        </p>
        <div class="bg-white/10 rounded-lg p-6">
          <form class="flex flex-col sm:flex-row gap-4">
            <input 
              type="email" 
              placeholder="Enter your email" 
              class="flex-1 px-4 py-3 rounded-lg text-gray-900 placeholder-gray-500"
              required
            />
            <button 
              type="submit"
              class="bg-brandGold hover:bg-yellow-600 text-black font-semibold px-6 py-3 rounded-lg transition-colors"
            >
              Subscribe
            </button>
          </form>
          <p class="text-sm opacity-75 mt-3">Get 3-5 new resources every month. Unsubscribe anytime.</p>
        </div>
      </div>
    </div>  </section>

  <Footer />
</Base>

<script>
  // Download functionality
  document.addEventListener('DOMContentLoaded', function() {
    const downloadButtons = document.querySelectorAll('.download-btn');
    const previewButtons = document.querySelectorAll('.preview-btn');
    
    // Handle downloads
    downloadButtons.forEach(button => {
      button.addEventListener('click', async function() {
        const downloadId = this.getAttribute('data-download-id');
        const downloadTitle = this.getAttribute('data-download-title');
        const downloadText = this.querySelector('.download-text');
        const downloadLoading = this.querySelector('.download-loading');
        
        // Show loading state
        this.disabled = true;
        downloadText.classList.add('hidden');
        downloadLoading.classList.remove('hidden');
        
        try {
          // Check if user wants to provide email for tracking
          const userEmail = await promptForEmail(downloadTitle);
          
          // Track download
          const response = await fetch('/api/download', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              downloadId,
              userEmail,
              downloadType: userEmail ? 'email-provided' : 'anonymous'
            }),
          });
          
          const result = await response.json();
          
          if (response.ok) {
            // Trigger download
            triggerDownload(result.downloadUrl, result.filename);
            
            // Show success message
            showDownloadSuccess(downloadTitle);
          } else {
            throw new Error(result.error || 'Download failed');
          }
        } catch (error) {
          console.error('Download error:', error);
          showDownloadError(error.message);
        } finally {
          // Reset button state
          this.disabled = false;
          downloadText.classList.remove('hidden');
          downloadLoading.classList.add('hidden');
        }
      });
    });
    
    // Handle previews
    previewButtons.forEach(button => {
      button.addEventListener('click', function() {
        const previewUrl = this.getAttribute('data-preview-url');
        if (previewUrl) {
          // Open preview in new tab
          window.open(previewUrl, '_blank');
        } else {
          // Show preview not available message
          showMessage('Preview not available for this resource.', 'info');
        }
      });
    });
  });
  
  // Prompt for email (optional)
  async function promptForEmail(downloadTitle) {
    return new Promise((resolve) => {
      const modal = createEmailModal(downloadTitle, resolve);
      document.body.appendChild(modal);
    });
  }
  
  // Create email modal
  function createEmailModal(downloadTitle, resolve) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4';
    
    modal.innerHTML = `
      <div class="bg-white rounded-lg max-w-md w-full p-6">
        <h3 class="text-xl font-bold text-gray-900 mb-4">Download ${downloadTitle}</h3>
        <p class="text-gray-600 mb-6">
          Get notified when we release new resources and receive our weekly analytics insights.
        </p>
        
        <form id="email-form" class="space-y-4">
          <div>
            <label for="download-email" class="block text-sm font-medium text-gray-700 mb-2">
              Email (optional)
            </label>
            <input 
              type="email" 
              id="download-email" 
              placeholder="your@email.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brandGreen focus:border-transparent"
            />
          </div>
          
          <div class="flex gap-3">
            <button 
              type="button" 
              id="skip-email"
              class="flex-1 border border-gray-300 text-gray-700 py-3 px-4 rounded-lg hover:bg-gray-50 transition-colors"
            >
              Download Without Email
            </button>
            <button 
              type="submit"
              class="flex-1 bg-brandGreen text-white py-3 px-4 rounded-lg hover:bg-green-700 transition-colors"
            >
              Download & Subscribe
            </button>
          </div>
        </form>
      </div>
    `;
    
    // Handle form submission
    const form = modal.querySelector('#email-form');
    const emailInput = modal.querySelector('#download-email');
    const skipButton = modal.querySelector('#skip-email');
    
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      document.body.removeChild(modal);
      resolve(email || null);
    });
    
    skipButton.addEventListener('click', () => {
      document.body.removeChild(modal);
      resolve(null);
    });
    
    // Close on backdrop click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        document.body.removeChild(modal);
        resolve(null);
      }
    });
    
    return modal;
  }
  
  // Trigger download
  function triggerDownload(url, filename) {
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    link.style.display = 'none';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  }
  
  // Show success message
  function showDownloadSuccess(title) {
    showMessage(`${title} download started successfully!`, 'success');
  }
  
  // Show error message
  function showDownloadError(message) {
    showMessage(`Download failed: ${message}`, 'error');
  }
  
  // Generic message display
  function showMessage(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `fixed top-4 right-4 z-50 p-4 rounded-lg shadow-lg max-w-sm ${
      type === 'success' ? 'bg-green-100 border border-green-400 text-green-700' :
      type === 'error' ? 'bg-red-100 border border-red-400 text-red-700' :
      'bg-blue-100 border border-blue-400 text-blue-700'
    }`;
    
    notification.innerHTML = `
      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          ${type === 'success' ? 
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>' :
            type === 'error' ?
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>' :
            '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>'
          }
        </svg>
        <span>${message}</span>
      </div>
    `;
    
    document.body.appendChild(notification);
    
    // Auto remove after 5 seconds
    setTimeout(() => {
      if (document.body.contains(notification)) {
        document.body.removeChild(notification);
      }
    }, 5000);
  }
</script>
