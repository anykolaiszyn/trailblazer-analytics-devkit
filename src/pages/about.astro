---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.jsx';

// SEO meta data
const seoData = {
  title: "About Alexander Trailblazer - Data Strategy Expert",
  description: "Meet Alexander Trailblazer, data strategy consultant and analytics expert helping organizations transform raw data into competitive advantage. 15+ years experience in BI and AI implementation.",
  image: "/og-image-about.png"
};
---

<Base {...seoData}>
  <Navbar />
  
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-900 to-gray-800 text-white py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <div class="w-32 h-32 bg-brandGold rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-black font-bold text-4xl">A</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          Meet <span class="text-brandGold">Alexander</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-8">
          Data strategist, analytics expert, and founder of Trailblazer Analytics. Transforming organizations through the power of data-driven decision making.
        </p>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Where Data Strategy Meets Action</h2>
            <p class="text-lg text-gray-600 mb-6">
              With over a decade of experience in business intelligence and analytics, Alexander has helped organizations across industries transform their relationship with data. From Fortune 500 companies to fast-growing startups, he brings a unique blend of strategic thinking and hands-on expertise.
            </p>
            <p class="text-lg text-gray-600 mb-6">
              Alexander founded Trailblazer Analytics with a simple belief: that every organization, regardless of size or industry, can harness the power of data to drive meaningful business outcomes. His approach combines proven methodologies with cutting-edge technology to create solutions that are both innovative and practical.
            </p>
            <div class="flex flex-wrap gap-4">
              <span class="bg-brandGreen/10 text-brandGreen px-4 py-2 rounded-full font-semibold">10+ Years Experience</span>
              <span class="bg-brandGold/10 text-orange-700 px-4 py-2 rounded-full font-semibold">50+ Organizations</span>
              <span class="bg-blue-100 text-blue-700 px-4 py-2 rounded-full font-semibold">Multiple Industries</span>
            </div>
          </div>
          
          <div class="bg-gray-50 rounded-2xl p-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">Core Expertise</h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-brandGreen rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Data Strategy & Governance</h4>
                  <p class="text-gray-600 text-sm">Developing comprehensive data strategies that align with business objectives</p>
                </div>
              </div>
              
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-brandGreen rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Business Intelligence & Analytics</h4>
                  <p class="text-gray-600 text-sm">Building BI systems that deliver actionable insights to stakeholders</p>
                </div>
              </div>
              
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-brandGreen rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">AI & Machine Learning Implementation</h4>
                  <p class="text-gray-600 text-sm">Practical AI solutions that solve real business problems</p>
                </div>
              </div>
              
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-brandGreen rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Data Storytelling & Communication</h4>
                  <p class="text-gray-600 text-sm">Transforming complex data into compelling narratives</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">Philosophy & Approach</h2>
        <div class="grid md:grid-cols-3 gap-8">
          <div class="bg-white rounded-xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-brandGreen/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-brandGreen" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Action-Oriented</h3>
            <p class="text-gray-600">
              Data without action is just information. Every strategy, framework, and solution is designed to drive measurable business outcomes.
            </p>
          </div>
          
          <div class="bg-white rounded-xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-brandGold/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">Practical First</h3>
            <p class="text-gray-600">
              Technology should serve the business, not the other way around. Solutions are built with real-world constraints and capabilities in mind.
            </p>
          </div>
          
          <div class="bg-white rounded-xl p-8 shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">People-Centered</h3>
            <p class="text-gray-600">
              Successful data initiatives require buy-in at every level. Change management and stakeholder engagement are built into every project.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Timeline -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Professional Journey</h2>
        
        <div class="space-y-8">
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-brandGreen rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Founder & Principal Consultant</h3>
              <p class="text-brandGreen font-semibold mb-2">Trailblazer Analytics • 2020 - Present</p>
              <p class="text-gray-600">
                Founded Trailblazer Analytics to help organizations transform their data capabilities. Leading strategic consulting engagements across multiple industries, from healthcare to financial services.
              </p>
            </div>
          </div>
          
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Senior Data Strategist</h3>
              <p class="text-gray-600 font-semibold mb-2">Enterprise Analytics Corp • 2017 - 2020</p>
              <p class="text-gray-600">
                Led data strategy initiatives for Fortune 500 clients, specializing in digital transformation and analytics modernization projects. Managed teams of 5-15 analytics professionals.
              </p>
            </div>
          </div>
          
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
              </div>
            </div>
            <div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">Business Intelligence Manager</h3>
              <p class="text-gray-600 font-semibold mb-2">TechStart Solutions • 2014 - 2017</p>
              <p class="text-gray-600">
                Built the BI function from ground up for a fast-growing technology company. Implemented data warehouse, reporting infrastructure, and analytics capabilities that scaled with business growth.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Credentials & Recognition -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Credentials & Recognition</h2>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div class="bg-white rounded-xl p-6 text-center shadow-lg">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Certified Analytics Professional</h3>
            <p class="text-gray-600 text-sm">Institute for Operations Research and the Management Sciences (INFORMS)</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 text-center shadow-lg">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Top Data Consultant</h3>
            <p class="text-gray-600 text-sm">Analytics Weekly "40 Under 40" Recognition (2022)</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 text-center shadow-lg">
            <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Published Author</h3>
            <p class="text-gray-600 text-sm">15+ articles in leading industry publications and journals</p>
          </div>
          
          <div class="bg-white rounded-xl p-6 text-center shadow-lg">
            <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M7 4a3 3 0 016 0v4a3 3 0 11-6 0V4zm4 10.93A7.001 7.001 0 0017 8a1 1 0 10-2 0A5 5 0 015 8a1 1 0 00-2 0 7.001 7.001 0 006 6.93V17H6a1 1 0 100 2h8a1 1 0 100-2h-3v-2.07z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">Speaker & Educator</h3>
            <p class="text-gray-600 text-sm">Keynote speaker at 20+ conferences and industry events</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-20 bg-brandGreen text-white">
    <div class="container mx-auto px-6">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Let's Work Together</h2>
        <p class="text-xl mb-8 opacity-90">
          Ready to transform your organization's relationship with data? Let's discuss how we can help you achieve your goals.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-brandGold hover:bg-yellow-600 text-black font-semibold py-4 px-8 rounded-lg transition-colors">
            Start a Conversation
          </a>
          <a href="/services" class="border-2 border-white text-white hover:bg-white hover:text-brandGreen font-semibold py-4 px-8 rounded-lg transition-colors">
            View Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
