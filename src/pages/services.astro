---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.jsx';
import ServiceCard from '../components/ServiceCard.jsx';
import { getCollection } from 'astro:content';
const caseStudies = await getCollection('caseStudies');
---

<Base>
  <Navbar />
  
  <!-- Header Section -->
  <section class="bg-gray-900 text-white py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Data Solutions That Drive Results</h1>
        <p class="text-xl text-gray-300 mb-8">
          From strategy to implementation, we provide comprehensive analytics services that transform your data into competitive advantage.
        </p>
        <a href="/contact" class="bg-brandGold text-gray-900 px-8 py-4 rounded-lg font-semibold hover:bg-yellow-500 transition-colors">
          Start Your Project
        </a>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Core Services</h2>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            End-to-end data solutions designed to accelerate your analytics maturity and drive measurable business outcomes.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Service 1 -->
          <div class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brandGreen rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Analytics Consulting</h3>
            <p class="text-gray-600 mb-6">Strategic guidance to build robust analytics capabilities, from data architecture to advanced reporting and insights.</p>
            <ul class="text-sm text-gray-500 space-y-2 mb-6">
              <li>• Data strategy development</li>
              <li>• Analytics roadmap planning</li>
              <li>• BI tool selection & implementation</li>
              <li>• Performance measurement frameworks</li>
            </ul>
            <a href="/contact" class="text-brandGreen font-medium hover:text-green-700 transition-colors">Learn More →</a>
          </div>

          <!-- Service 2 -->
          <div class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brandGreen rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">AI-Powered Applications</h3>
            <p class="text-gray-600 mb-6">Custom AI solutions that automate processes, enhance decision-making, and unlock new revenue opportunities.</p>
            <ul class="text-sm text-gray-500 space-y-2 mb-6">
              <li>• Machine learning model development</li>
              <li>• Predictive analytics solutions</li>
              <li>• Natural language processing</li>
              <li>• Computer vision applications</li>
            </ul>
            <a href="/contact" class="text-brandGreen font-medium hover:text-green-700 transition-colors">Learn More →</a>
          </div>

          <!-- Service 3 -->
          <div class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brandGreen rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Data Storytelling Workshops</h3>
            <p class="text-gray-600 mb-6">Transform your team's ability to communicate insights effectively through compelling data narratives and visualizations.</p>
            <ul class="text-sm text-gray-500 space-y-2 mb-6">
              <li>• Executive presentation training</li>
              <li>• Visualization best practices</li>
              <li>• Narrative structure frameworks</li>
              <li>• Stakeholder communication</li>
            </ul>
            <a href="/contact" class="text-brandGreen font-medium hover:text-green-700 transition-colors">Learn More →</a>
          </div>

          <!-- Service 4 -->
          <div class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brandGreen rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Data Engineering</h3>
            <p class="text-gray-600 mb-6">Scalable data infrastructure and pipelines that ensure reliable, high-quality data for analytics and AI initiatives.</p>
            <ul class="text-sm text-gray-500 space-y-2 mb-6">
              <li>• ETL/ELT pipeline development</li>
              <li>• Data warehouse design</li>
              <li>• Real-time data processing</li>
              <li>• Data quality frameworks</li>
            </ul>
            <a href="/contact" class="text-brandGreen font-medium hover:text-green-700 transition-colors">Learn More →</a>
          </div>

          <!-- Service 5 -->
          <div class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brandGreen rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Team Training & Development</h3>
            <p class="text-gray-600 mb-6">Upskill your teams with hands-on training programs designed to build lasting analytics capabilities within your organization.</p>
            <ul class="text-sm text-gray-500 space-y-2 mb-6">
              <li>• Analytics skills assessment</li>
              <li>• Custom training curricula</li>
              <li>• Hands-on workshops</li>
              <li>• Certification programs</li>
            </ul>
            <a href="/contact" class="text-brandGreen font-medium hover:text-green-700 transition-colors">Learn More →</a>
          </div>

          <!-- Service 6 -->
          <div class="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brandGreen rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-4">Digital Transformation</h3>
            <p class="text-gray-600 mb-6">Comprehensive transformation initiatives that modernize your data ecosystem and accelerate time-to-insight.</p>
            <ul class="text-sm text-gray-500 space-y-2 mb-6">
              <li>• Cloud migration strategies</li>
              <li>• Legacy system modernization</li>
              <li>• Process automation</li>
              <li>• Change management</li>
            </ul>
            <a href="/contact" class="text-brandGreen font-medium hover:text-green-700 transition-colors">Learn More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Proven Process</h2>
        <p class="text-xl text-gray-600">
          A systematic approach that ensures successful outcomes and sustainable results.
        </p>
      </div>

      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-4 gap-8">
          <!-- Step 1 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brandGreen rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-white font-bold text-xl">1</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Discovery</h3>
            <p class="text-gray-600 text-sm">Understand your business goals, data landscape, and current challenges.</p>
          </div>

          <!-- Step 2 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brandGreen rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-white font-bold text-xl">2</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Strategy</h3>
            <p class="text-gray-600 text-sm">Develop a comprehensive roadmap aligned with your business objectives.</p>
          </div>

          <!-- Step 3 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brandGreen rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-white font-bold text-xl">3</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Implementation</h3>
            <p class="text-gray-600 text-sm">Execute solutions with agile methodologies and continuous stakeholder engagement.</p>
          </div>

          <!-- Step 4 -->
          <div class="text-center">
            <div class="w-16 h-16 bg-brandGreen rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-white font-bold text-xl">4</span>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Optimization</h3>
            <p class="text-gray-600 text-sm">Monitor performance, gather feedback, and continuously improve outcomes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Client Success Stories</h2>
          <p class="text-xl text-gray-600">
            See how we've helped organizations transform their data capabilities and achieve measurable results.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {caseStudies.slice(0, 3).map((study) => (
            <div class="bg-white border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
              <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-2">{study.data.title}</h3>
                <p class="text-gray-600 text-sm mb-4">{study.data.description}</p>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-gray-500">{study.data.industry}</span>
                  <a href={`/case-studies/${study.slug}`} class="text-brandGreen text-sm font-medium hover:text-green-700">Read Case Study →</a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <a href="/case-studies" class="bg-brandGreen text-white px-8 py-3 rounded-lg hover:bg-green-700 transition-colors">
            View All Case Studies
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gray-900 text-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Transform Your Data Strategy?</h2>
        <p class="text-xl text-gray-300 mb-8">
          Let's discuss how we can help you unlock the full potential of your data and drive meaningful business outcomes.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-brandGold text-gray-900 px-8 py-4 rounded-lg font-semibold hover:bg-yellow-500 transition-colors">
            Start Your Project
          </a>
          <a href="/downloads" class="border-2 border-brandGold text-brandGold px-8 py-4 rounded-lg font-semibold hover:bg-brandGold hover:text-gray-900 transition-colors">
            Download Free Resources
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
